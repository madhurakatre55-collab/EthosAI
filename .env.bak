# ============================================================================
# EthosAI Environment Configuration
# ============================================================================

# API Keys and Model Configuration
GEMINI_API_KEY=Api_key
GEMINI_MODEL=gemini/gemini-1.5-flash

# File and Directory Paths
LOG_FILE_PATH=./task_outputs/log.txt
OUTPUT_DIR=./task_outputs
DATA_DIR=./data

# Logging Configuration
LOG_LEVEL=INFO
SAVE_LOGS_TO_FILE=True

# Execution Settings
MAX_EXECUTION_TIME=600
BATCH_SIZE=100
SAMPLE_SIZE=1000

# Application Features
ETHOS_VERBOSE=True
ETHOS_CACHE=True
DEBUG_MODE=False
USE_SYSTEM_PROMPT=True

# Bias Detection Configuration
ENABLE_BIAS_DETECTION=True
ENABLE_BIAS_EXPLANATION=True
ENABLE_FIX_RECOMMENDATIONS=True
BIAS_THRESHOLD=0.7

# Model Updates and Logging
ENABLE_MODEL_UPDATES=True
ENABLE_LOG_GENERATION=True
ENABLE_LOG_INSIGHTS=True

# LLM Model Parameters
LLM_TEMPERATURE=0.6
LLM_TOP_P=0.9
LLM_MAX_TOKENS=4096
RESPECT_CONTEXT_WINDOW=True

# Report Generation
SAVE_DETAILED_REPORT=True
REPORT_FORMAT=txt
INCLUDE_RAW_OUTPUT=True

# Application Info
ENVIRONMENT=development
APP_VERSION=1.0.0
