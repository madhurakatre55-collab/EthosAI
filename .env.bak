# Environment Variables

## Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ethosai_db
DB_USER=ethosai_user
DB_PASSWORD=secure_password

## API Settings
API_URL=https://api.ethosai.com
API_KEY=YOUR_API_KEY_HERE

## Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000

# Miscellaneous
LOG_LEVEL=info
SESSION_SECRET=your_session_secret
